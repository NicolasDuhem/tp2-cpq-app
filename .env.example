# TP2-CPQ-App environment example
# Copy to .env.local for local development. Never commit real secrets.

# Database
# Required for runtime database access. Sensitive.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# Auth bootstrap
# Required only when running the first-admin bootstrap script. Do not reuse in normal runtime.
APP_BOOTSTRAP_ADMIN_EMAIL="admin@example.com"
APP_BOOTSTRAP_ADMIN_NAME="Admin User"
APP_BOOTSTRAP_ADMIN_PASSWORD="change-me-long-password"

# CPQ runtime
# CPQ_API_KEY is required unless CPQ_USE_MOCK="true" avoids downstream CPQ calls. Sensitive.
CPQ_API_KEY="your_cpq_api_key"
CPQ_BASE_URL="https://configurator.eu1.inforcloudsuite.com/api/v4/ProductConfiguratorUI.svc/json"
CPQ_TIMEOUT_MS="25000"
CPQ_INSTANCE="your_cpq_instance"
CPQ_PROFILE="Default"
CPQ_NAMESPACE="Default"
CPQ_PART_NAME="your_cpq_part_name"
CPQ_ACCOUNT_TYPE="Dealer"
CPQ_CURRENCY="GBP"
CPQ_COMPANY="your_cpq_company_code"
CPQ_CUSTOMER_LOCATION="GB"
CPQ_HEADER_ID="your_cpq_header_id"
CPQ_DETAIL_ID="your_cpq_detail_id"
CPQ_USE_MOCK="false"
CPQ_DEBUG="false"

# CPQ canonical copy capability
# Optional unless enabling ProductConfigurator CopyConfiguration. Secrets use placeholders only.
CPQ_COPY_CONFIGURATION_URL="https://your_cpq_copy_configuration_endpoint"
CPQ_COPY_API_KEY="your_cpq_copy_api_key"
CPQ_COPY_REQUEST_WRAPPER=""
CPQ_COPY_TIMEOUT_MS="25000"

# Browser-visible CPQ values
# NEXT_PUBLIC_* values are bundled into client-side JavaScript. Never put secrets here.
NEXT_PUBLIC_CPQ_DEBUG="false"
NEXT_PUBLIC_CPQ_INSTANCE="your_public_cpq_instance"

# BigCommerce variant status checks
# Access token is sensitive. Store hash is operationally sensitive and should be protected.
BIGCOMMERCE_API_BASE_URL="https://api.bigcommerce.com"
BIGCOMMERCE_STORE_HASH="your_store_hash"
BIGCOMMERCE_ACCESS_TOKEN="your_bigcommerce_access_token"
BIGCOMMERCE_BC_STATUS_ENABLED="true"
BIGCOMMERCE_API_TIMEOUT_MS="10000"
BIGCOMMERCE_VARIANT_CHECK_BATCH_SIZE="25"

# External PostgreSQL row push/sync
# Required only for allocation external push/status refresh features. Password is sensitive.
EXTERNAL_PG_HOST="hostname.example.com"
EXTERNAL_PG_PORT="5432"
EXTERNAL_PG_DATABASE="appdb"
EXTERNAL_PG_USER="app_user"
EXTERNAL_PG_PASSWORD="your_external_pg_password"
EXTERNAL_PG_SSL="true"
EXTERNAL_PG_SSL_REJECT_UNAUTHORIZED="false"
EXTERNAL_PG_SCHEMA="public"
EXTERNAL_PG_CONNECT_TIMEOUT_MS="8000"
EXTERNAL_PG_QUERY_TIMEOUT_MS="12000"
EXTERNAL_PG_STATEMENT_TIMEOUT_MS="12000"
EXTERNAL_VARIANT_TABLE_WRITE_CONCURRENCY="5"

# Vercel Blob (QPart image upload/delete)
# Required where QPart image upload/delete is enabled. Sensitive.
BLOB_READ_WRITE_TOKEN="your_vercel_blob_read_write_token"

# QPart allocation Update all password
# Required to override the unsafe in-code legacy fallback. Sensitive.
QPART_UPDATE_ALL_PASSWORD="your_qpart_update_all_password"

# OpenAI QPart translation
# Required only for QPart AI translation. API key is sensitive.
OPENAI_API_KEY="your_openai_api_key"
OPENAI_TRANSLATION_MODEL="gpt-5.4-mini"
